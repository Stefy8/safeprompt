  },
  "keywords": [
    "privacy",
    "pii",
    "ai-safety",
    "browser-extension",
    "chrome-extension",
    "chatgpt",
    "claude",
    "gemini",
    "data-protection",
    "open-source",
    "arabic",
    "multilingual"
  ],
  "scripts": {
